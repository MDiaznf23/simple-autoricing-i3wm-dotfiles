;;; BATTERY TOOLTIPS WIDGET

(defvar show_battery_tooltip false)

(defwidget battery_tooltips []
  (box :orientation "v"
       :space-evenly true 
       :spacing 5
       :class "battery-tooltip-container"
    (label :text "Model: ${system_status.bat_model}")
))

(defwindow battery-tooltip-window
  :stacking "overlay"
  :focusable false
  :exclusive false
  :windowtype "dialog"
  :geometry (geometry 
    :x "-140px"
    :y "45px"
    :anchor "top right")
  (battery_tooltips))

