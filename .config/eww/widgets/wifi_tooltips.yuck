;;; WIFI TOOLTIPS WIDGET

(defvar show_wifi_tooltip false)

(defwidget wifi_tooltips []
  (box :orientation "v"
       :space-evenly true 
       :spacing 5
       :class "wifi-tooltip-container"
    (label :text {system_status.wifi_connected ? "Connected to: ${system_status.wifi_ssid}" : "Disconnected"})
    (label :text "Signal Strength: ${system_status.wifi_signal}%")
    (label :text "Security: ${system_status.wifi_security}"))
)

(defwindow wifi-tooltip-window
  :stacking "overlay"
  :focusable false
  :exclusive false
  :windowtype "dialog"
  :geometry (geometry 
    :x "-200px"
    :y "45px"
    :anchor "top right")
  (wifi_tooltips))
